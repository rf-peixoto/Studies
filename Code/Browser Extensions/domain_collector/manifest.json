{
  "manifest_version": 2,
  "name": "Domain Feed",
  "version": "1.0",
  "description": "Collects visited domains and feeds them to a local server.",
  "permissions": [
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Domain Feed"
  }
}
